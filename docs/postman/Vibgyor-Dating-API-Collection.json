          "let json;",
          "try {",
          "    json = pm.response.json();",
          "} catch (err) {",
          "    return;",
          "}",
          "",
          "const data = json?.data || {};",
          "",
          "// Extract targetUserId from various response formats",
          "if (data.datingProfile?._id) {",
          "    pm.collectionVariables.set('targetUserId', data.datingProfile._id);",
          "}",
          "if (Array.isArray(data.profiles) && data.profiles.length > 0) {",
          "    const firstProfile = data.profiles[0];",
          "    pm.collectionVariables.set('targetUserId', firstProfile._id || firstProfile.userId || '');",
          "}",
          "if (data.profile?._id) {",
          "    pm.collectionVariables.set('targetUserId', data.profile._id);",
          "}",
          "",
          "// Extract matchId",
          "if (data.matchId) {",
          "    pm.collectionVariables.set('matchId', data.matchId);",
          "}",
          "if (data.matches && Array.isArray(data.matches) && data.matches.length > 0) {",
          "    const firstMatch = data.matches[0];",
          "    pm.collectionVariables.set('matchId', firstMatch.matchId || firstMatch._id || '');",
          "}",
          "",
          "// Extract commentId",
          "if (data.comment?._id) {",
          "    pm.collectionVariables.set('commentId', data.comment._id);",
          "}",
          "if (data.comments && Array.isArray(data.comments) && data.comments.length > 0) {",
          "    const firstComment = data.comments[0];",
          "    pm.collectionVariables.set('commentId', firstComment._id || firstComment.id || '');",
          "}"
